---
layout: layouts/base.njk
title: All Posts
permalink: /tags/
---

<h1 class="mita">all posts</h1>
<hr>
<p><a href="/"><- home</a></p>

{% set tagList = collections.allPosts | getAllTags | sort %}

<ul style="list-style:none; padding:0; display:flex; flex-wrap:wrap; gap:0.75rem; margin-bottom:1.25rem;">
{% for tag in tagList %}
  {% if tag != 'allPosts' %}
  <li>
    <a class="button-box" style="display:inline-block; padding:0.45rem 0.9rem; text-decoration:none; font-size:0.92em;" href="/tags/{{ tag }}/">
      #{{ tag }} <span style="opacity:0.7;">({{ collections[tag].length }})</span>
    </a>
  </li>
  {% endif %}
{% endfor %}
</ul>

{% set posts = collections.allPosts | sortByDateDesc %}

<ul style="list-style:none; padding:0;">
{% for post in posts %}
  <li style="margin: 0.55rem 0; line-height: 1.35;">
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <time style="color:#888; font-size:0.82em; margin-left:0.5em;">{{ post.date | readableDate }}</time>
    {% if post.data.tags and post.data.tags.length > 0 %}
      <span style="font-size:0.72em; color:#888; margin-left:0.4em;">
        | {{ post.data.tags | join(', ') }}
      </span>
    {% endif %}
  </li>
{% else %}
  <li>no posts yet.</li>
{% endfor %}
</ul>
